local cfg       = _G.AimbotCfg
local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local enabled       = false
local target        = nil
local visualsOn     = true
local unloaded      = false
local displayedHP   = 1
local speedOn       = false
local originalSpeed = nil

local function applyEasing(t)
    local e = cfg.easingType
    if e == "quad"  then return t*t
    elseif e == "cubic" then return t*t*t
    elseif e == "sine"  then return 1 - math.cos(t * math.pi * 0.5)
    elseif e == "exp"   then return t == 0 and 0 or 2^(10*(t-1))
    end
    return t
end

local function makeAlpha(s, dt)
    local raw = 1 - (1 - math.clamp(s, 0.01, 0.99))^(dt * 60)
    return applyEasing(math.clamp(raw, 0, 1))
end

local sg = Instance.new("ScreenGui")
sg.Name           = "AimbotVisuals"
sg.ResetOnSpawn   = false
sg.IgnoreGuiInset = true
sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
sg.Parent         = player.PlayerGui

local hpBg = Instance.new("Frame")
hpBg.BackgroundColor3 = cfg.hpBarBgColor
hpBg.BorderSizePixel  = 0
hpBg.Visible          = false
hpBg.Parent           = sg

local hpFill = Instance.new("Frame")
hpFill.AnchorPoint      = Vector2.new(0, 1)
hpFill.Position         = UDim2.new(0, 0, 1, 0)
hpFill.BackgroundColor3 = cfg.hpBarFgColor
hpFill.BorderSizePixel  = 0
hpFill.Parent           = hpBg

local modeLbl = Instance.new("TextLabel")
modeLbl.Size                   = UDim2.new(0, 200, 0, 24)
modeLbl.Position               = UDim2.new(0, 10, 0, 10)
modeLbl.BackgroundTransparency = 1
modeLbl.TextColor3             = Color3.fromRGB(255, 255, 255)
modeLbl.Font                   = Enum.Font.GothamBold
modeLbl.TextSize               = 13
modeLbl.TextXAlignment         = Enum.TextXAlignment.Left
modeLbl.Text                   = ""
modeLbl.Visible                = false
modeLbl.Parent                 = sg

local function showMode()
    modeLbl.Text             = cfg.npcOnly and "Mode: NPC" or "Mode: Players"
    modeLbl.Visible          = true
    modeLbl.TextTransparency = 0
    task.delay(1.5, function()
        if unloaded then return end
        for i = 1, 20 do
            if unloaded then break end
            modeLbl.TextTransparency = i / 20
            task.wait(0.05)
        end
        modeLbl.Visible = false
    end)
end

local function safeToScreen(pos)
    local ok, sp, vis = pcall(function()
        return camera:WorldToViewportPoint(pos)
    end)
    if not ok then return nil, false end
    return sp, vis
end

local function isOccluded(worldPos)
    local char   = player.Character
    local origin = camera.CFrame.Position
    local dir    = worldPos - origin
    local dist   = dir.Magnitude
    if dist < 0.1 then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local excluded = {workspace.Terrain}
    if char   then table.insert(excluded, char)   end
    if target then table.insert(excluded, target) end
    params.FilterDescendantsInstances = excluded
    return workspace:Raycast(origin, dir.Unit * dist, params) ~= nil
end

local function targetGone(model)
    if not model or not model.Parent then return true end
    return model:FindFirstChildWhichIsA("Humanoid") == nil
end

local function getState(model)
    local hum = model:FindFirstChildWhichIsA("Humanoid")
    if not hum then return "ground" end
    local s = hum:GetState()
    if s == Enum.HumanoidStateType.Jumping  then return "jumping" end
    if s == Enum.HumanoidStateType.Freefall then return "falling" end
    return "ground"
end

local function getHitPart(model)
    local s = getState(model)
    local n
    if s == "jumping" then n = cfg.jumpHitPart
    elseif s == "falling" then n = cfg.fallHitPart
    else n = cfg.defaultHitPart end
    return model:FindFirstChild(n)
        or model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("UpperTorso")
        or model:FindFirstChild("Torso")
end

local function getPred(model)
    local s = getState(model)
    if s == "jumping" then return cfg.jumpPredictionX, cfg.jumpPredictionY end
    if s == "falling" then return cfg.fallPredictionX, cfg.fallPredictionY end
    return cfg.predictionX, cfg.predictionY
end

local function getCharBounds(model)
    local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
    local any = false
    for _, p in ipairs(model:GetDescendants()) do
        if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
            local sp, vis = safeToScreen(p.Position)
            if vis and sp then
                any  = true
                minX = math.min(minX, sp.X)
                minY = math.min(minY, sp.Y)
                maxX = math.max(maxX, sp.X)
                maxY = math.max(maxY, sp.Y)
            end
        end
    end
    if not any then return nil end
    return minX, minY, maxX, maxY
end

local function clearLock()
    target       = nil
    displayedHP  = 1
    hpBg.Visible = false
end

local function setSpeed(on)
    local char = player.Character
    local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
    if not hum then return end
    if on then
        if not originalSpeed then originalSpeed = hum.WalkSpeed end
        hum.WalkSpeed = cfg.walkSpeed
    else
        if originalSpeed then
            hum.WalkSpeed = originalSpeed
            originalSpeed = nil
        end
    end
end

local function tickSpeed()
    if not speedOn then return end
    local char = player.Character
    local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
    if hum and hum.WalkSpeed ~= cfg.walkSpeed then
        hum.WalkSpeed = cfg.walkSpeed
    end
end

local function findTarget()
    local myChar = player.Character
    if not myChar then return nil end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    local mouse      = UserInputService:GetMouseLocation()
    local mouseX     = mouse.X
    local mouseY     = mouse.Y
    local best       = nil
    local bestDist   = cfg.mouseRadius
    local candidates = {}

    if cfg.npcOnly then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj ~= myChar then
                if not Players:GetPlayerFromCharacter(obj) then
                    local hum = obj:FindFirstChildWhichIsA("Humanoid")
                    local r   = obj:FindFirstChild("HumanoidRootPart")
                    if hum and r then
                        table.insert(candidates, obj)
                    end
                end
            end
        end
    else
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                table.insert(candidates, p.Character)
            end
        end
    end

    for _, model in ipairs(candidates) do
        local hum = model:FindFirstChildWhichIsA("Humanoid")
        local r   = model:FindFirstChild("HumanoidRootPart")
        if not hum or not r or hum.Health <= 0 then continue end
        local worldDist = (r.Position - myRoot.Position).Magnitude
        if worldDist > cfg.range then continue end
        if cfg.teamCheck then
            local tp = Players:GetPlayerFromCharacter(model)
            if tp and player.Team and tp.Team == player.Team then continue end
        end
        local sp, vis = safeToScreen(r.Position)
        if not vis or not sp then continue end
        local dx = sp.X - mouseX
        local dy = sp.Y - mouseY
        local screenDist = math.sqrt(dx*dx + dy*dy)
        if screenDist < bestDist then
            best     = model
            bestDist = screenDist
        end
    end

    return best
end

local loopConn = RunService.RenderStepped:Connect(function(dt)
    if unloaded then return end
    tickSpeed()
    if cfg.autoStopOnDeath and enabled then
        local ch = player.Character
        local h  = ch and ch:FindFirstChildWhichIsA("Humanoid")
        if h and h.Health <= 0 then
            enabled = false
            clearLock()
            return
        end
    end
    if not enabled then
        hpBg.Visible = false
        return
    end
    if target and targetGone(target) then clearLock() end
    if not target then hpBg.Visible = false return end
    local aimPart = getHitPart(target)
    if not aimPart then clearLock() return end
    local predX, predY = getPred(target)
    local vel = aimPart.AssemblyLinearVelocity
    local cr  = camera.CFrame.RightVector
    local rl  = Vector3.new(vel.X, 0, vel.Z):Dot(cr) * predX
    local aimPos = aimPart.Position
        + cr * (cfg.offsetX + rl)
        + Vector3.new(0, cfg.offsetY + vel.Y * predY, 0)
    local curCF = camera.CFrame
    local tgtCF = CFrame.lookAt(curCF.Position, aimPos)
    local aX    = makeAlpha(cfg.smoothnessX, dt)
    local aY    = makeAlpha(cfg.smoothnessY, dt)
    local newCF = curCF:Lerp(tgtCF, (aX + aY) * 0.5)
    camera.CFrame = CFrame.new(curCF.Position) * (newCF - newCF.Position)
    local hum = target:FindFirstChildWhichIsA("Humanoid")
    local minX, minY, maxX, maxY = getCharBounds(target)
    if minX and hum and hum.MaxHealth > 0 then
        local realFrac = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        displayedHP    = displayedHP + (realFrac - displayedHP)
            * math.clamp(cfg.hpBarSmoothing, 0.01, 1)
        if cfg.autoStopOnDeath and displayedHP <= cfg.hpBarDeathThreshold then
            clearLock()
            enabled = false
            return
        end
        if not visualsOn or not cfg.hpBarEnabled then
            hpBg.Visible = false
            return
        end
        local root = target:FindFirstChild("HumanoidRootPart")
        if root and isOccluded(root.Position) then
            hpBg.Visible = false
            return
        end
        local charH = math.max(maxY - minY, 10)
        local barX  = cfg.hpBarSide == "left"
            and (minX - cfg.hpBarOffsetX - cfg.hpBarWidth)
            or  (maxX + cfg.hpBarOffsetX)
        hpBg.Visible  = true
        hpBg.Size     = UDim2.new(0, cfg.hpBarWidth, 0, charH)
        hpBg.Position = UDim2.new(0, barX, 0, minY)
        hpFill.Size   = UDim2.new(1, 0, displayedHP, 0)
        hpFill.BackgroundColor3 = displayedHP < 0.25 and cfg.hpBarLowColor
            or displayedHP < 0.5 and cfg.hpBarMidColor
            or cfg.hpBarFgColor
    else
        hpBg.Visible = false
    end
end)

UserInputService.InputBegan:Connect(function(input)
    if unloaded then return end
    if input.KeyCode == Enum.KeyCode.E then
        if not enabled then
            enabled = true
            local t = findTarget()
            if t then target = t; displayedHP = 1 end
        elseif target then
            clearLock()
        else
            enabled = false
            clearLock()
        end
    end
    if input.KeyCode == Enum.KeyCode.Q then
        speedOn = not speedOn
        setSpeed(speedOn)
    end
    if input.KeyCode == Enum.KeyCode.F4 then
        cfg.npcOnly = not cfg.npcOnly
        clearLock()
        showMode()
    end
    if input.KeyCode == Enum.KeyCode.F2 then
        visualsOn = not visualsOn
        if not visualsOn then hpBg.Visible = false end
    end
    if input.KeyCode == Enum.KeyCode.F3 then
        unloaded = true
        enabled  = false
        speedOn  = false
        setSpeed(false)
        clearLock()
        pcall(function() sg:Destroy() end)
        pcall(function() loopConn:Disconnect() end)
    end
end)
